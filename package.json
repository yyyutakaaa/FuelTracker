{
  "name": "fueltracker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Route- en brandstofkostencalculator voor België en Nederland.",
  "scripts": {
    "dev": "npm run prepare:vendor && npm run build:css && vite",
    "prepare:vendor": "node ./scripts/prepare-vendor.js",
    "build:css": "tailwindcss -i ./css/tailwind-input.css -o ./css/tailwind.generated.css --minify",
    "build": "npm run prepare:vendor && npm run build:css && vite build",
    "preview": "vite preview",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.3.1",
    "chart.js": "4.5.1",
    "leaflet": "1.9.4",
    "vue": "3.5.40"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17",
    "vite": "8.1.5"
  }
}
